{
  "dashboard": {
    "title": "AetherLife Trading System - 核心指标",
    "uid": "aetherlife-core",
    "tags": ["aetherlife", "trading"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "系统健康状态",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=\"aetherlife_core\"}",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "value": "1", "text": "运行中", "color": "green"},
              {"type": "value", "value": "0", "text": "离线", "color": "red"}
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "总资产净值 (USD)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "targets": [
          {
            "expr": "aetherlife_portfolio_total_value",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          }
        }
      },
      {
        "id": 3,
        "title": "今日收益率 (%)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "aetherlife_portfolio_daily_return",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 0, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "活跃订单数",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(aetherlife_active_orders)",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "id": 5,
        "title": "Sharpe Ratio (7日)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "targets": [
          {
            "expr": "aetherlife_sharpe_ratio_7d",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1.0, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "最大回撤 (%)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
        "targets": [
          {
            "expr": "aetherlife_max_drawdown",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": -10, "color": "yellow"},
                {"value": -20, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "权益曲线",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "aetherlife_portfolio_total_value",
            "refId": "A",
            "legendFormat": "总资产"
          }
        ],
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"}
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 8,
        "title": "各品种持仓占比",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "aetherlife_position_value by (symbol)",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right"}
        }
      },
      {
        "id": 9,
        "title": "每秒交易数 (TPS)",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "rate(aetherlife_trades_total[1m])",
            "refId": "A",
            "legendFormat": "TPS"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 10,
        "title": "订单延迟 (ms)",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(aetherlife_order_latency_bucket[5m]))",
            "refId": "A",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(aetherlife_order_latency_bucket[5m]))",
            "refId": "B",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 11,
        "title": "Agent决策权重",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 12},
        "targets": [
          {
            "expr": "aetherlife_agent_weight by (agent)",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right"}
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 5,
              "stacking": {"mode": "normal"}
            }
          }
        }
      },
      {
        "id": 12,
        "title": "风险指标",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
        "targets": [
          {
            "expr": "aetherlife_var_1day_95",
            "refId": "A",
            "legendFormat": "VaR 1日95%"
          },
          {
            "expr": "aetherlife_var_1day_99",
            "refId": "B",
            "legendFormat": "VaR 1日99%"
          },
          {
            "expr": "aetherlife_cvar_95",
            "refId": "C",
            "legendFormat": "CVaR 95%"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        }
      },
      {
        "id": 13,
        "title": "系统资源使用",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 18},
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"aetherlife_core\"}[1m])",
            "refId": "A",
            "legendFormat": "CPU"
          },
          {
            "expr": "process_resident_memory_bytes{job=\"aetherlife_core\"} / 1024 / 1024",
            "refId": "B",
            "legendFormat": "内存 (MB)"
          }
        ]
      },
      {
        "id": 14,
        "title": "异常告警",
        "type": "logs",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "{job=\"aetherlife_core\", level=\"ERROR\"}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
